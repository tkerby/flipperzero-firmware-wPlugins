App(
    appid="flipdeck",
    name="FlipDeck",
    apptype=FlipperAppType.EXTERNAL,
    entry_point="flipdeck_main",
    stack_size=4 * 1024,
    fap_icon="icon.png",
    fap_category="USB",
    fap_description="USB HID Macro Pad with configurable pages",
    fap_author="FlipDeck",
    fap_version="3.0",
    fap_weburl="https://github.com/flipdeck/flipdeck",
    requires=["gui", "storage", "notification"],
)
